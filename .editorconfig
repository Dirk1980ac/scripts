root = true

[*]
indent_style = tab
indent_size = 4
shell_variant      = auto
binary_next_line   = true
switch_case_indent = true
space_redirects    = true
keep_padding       = true
function_next_line = true

[*.md]
tab_width = 4
end_of_line = lf
charset = utf-8
indent_style = tab
trim_trailing_whitespace = false
