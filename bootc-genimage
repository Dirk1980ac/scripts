#!/bin/bash

set -eo pipefail

# Print a hopefully useful help text.
help() {
	cat << EOF

USAGE: $(basename $0) [-a <TARGET_ARCH>] -i <IMAGE_NAME> -t <OUTPUT_TYPE>

Options:
	-a                    Image arch (amd64, arm64) for cross building
	-i                    Image (mandatory)
    -t <type>             Output type (raw, qcow2, anaconda-iso, ...) (mandatory)
    -h                    Show this help

EOF
	exit 1
}

# Check command line options
while getopts "a: i:t:h" flag; do
	case $flag in
		a)
			TARGET=$OPTARG
			if [ "$TARGET" == "amd64" ]; then
				platform="linux/amd64"
			elif [ "$TARGET" == "arm64" ]; then
				platform="linux/arm64"
			fi
			;;
		t) TYPE=$OPTARG ;; # Store the image type provided by the user.
		i) IMAGE=$OPTARG ;; # Store the image path provided by the user.
		h) help ;; # Call the help function to display usage information.
		*) help ;;
	esac
done

if [[ -z $IMAGE || -z $TYPE  ]]; then
	help
fi

if [[ ! -z $TARGET && ! -z $platform ]]; then
	sudo podman pull --platform $platform $IMAGE
	sudo podman run \
		--rm \
		-it \
		--platform $platform \
		--privileged \
		--pull=always \
		--network host \
		--security-opt label=type:unconfined_t \
		-v ./config.toml:/config.toml:ro \
		-v .:/output \
		-v /var/lib/containers/storage:/var/lib/containers/storage \
		quay.io/centos-bootc/bootc-image-builder:latest \
		--type $TYPE \
		--target-arch $TARGET \
		--rootfs ext4 \
		--chown $UID:$GID \
		$IMAGE
else
	sudo podman pull $IMAGE
	sudo podman run \
		--rm \
		-it \
		--privileged \
		--pull=always \
		--network host \
		--security-opt label=type:unconfined_t \
		-v ./config.toml:/config.toml:ro \
		-v .:/output \
		-v /var/lib/containers/storage:/var/lib/containers/storage \
		quay.io/centos-bootc/bootc-image-builder:latest \
		--type $TYPE \
		--rootfs ext4 \
		--chown $UID:$GID \
		$IMAGE
fi

# Run the containerized bootc-image-builder tool with specified options.
# The resulting image file is chowned to the calling user.
