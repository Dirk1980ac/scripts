#!/bin/bash

set -eo pipefail

help() {
	echo "USAGE: $0 [-a <TARGET_ARCH>] -i <IMAGE_NAME> -t <OUTPUT_TYPE>"
	exit 1
}

[[ -z "$1" ]] && help

while getopts "a:i:t:h" flag; do
	case $flag in
		a) TARGET=$OPTARG ;;
		i) IMAGE=$OPTARG ;;
		t) TYPE=$OPTARG ;;
		h) help ;;
		*) help ;;
	esac
done

# Add input validation for required arguments
[[ -z "$IMAGE" ]] && {
	echo "Error: Image name is missing."
	help
	exit 1
}

[[ -z "$TYPE" ]] && {
	echo "Error: Output type is missing."
	help
	exit 1
}

if [[ -n "$TARGET" ]]; then
	case $TARGET in
		amd64) platform="linux/amd64" ;;
		arm64) platform="linux/arm64" ;;
		*) {
			echo "Error: Unsupported target architecture."
			exit 1
		} ;;
	esac
fi

sudo podman pull ${platform:+--platform "$platform"} "$IMAGE"

sudo podman run \
	--rm \
	-it \
	--privileged \
	--pull=always \
	--network host \
	--security-opt label=type:unconfined_t \
	${platform:+--platform "$platform"} \
	-v ./config.toml:/config.toml:ro \
	-v .:/output \
	-v /var/lib/containers/storage:/var/lib/containers/storage \
	quay.io/centos-bootc/bootc-image-builder:latest \
	--type "$TYPE" \
	${TARGET:+--target-arch "$TARGET"} \
	--rootfs ext4 \
	--chown "$UID:$GID" \
	"$IMAGE"
